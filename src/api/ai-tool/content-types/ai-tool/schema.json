{
  "kind": "collectionType",
  "collectionName": "ai_tools",
  "info": {
    "singularName": "ai-tool",
    "pluralName": "ai-tools",
    "displayName": "AI Tool",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "toolName": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "unique": true
    },
    "toolImage": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "developers": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "description": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "toolTags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tool-tag.tool-tag",
      "inversedBy": "aiTools"
    },
    "webToolLink": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "regex": "^(https?|ftp)://[^\\s/$.?#].[^\\s]*$"
    },
    "githubLink": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "regex": "^(https?|ftp)://[^\\s/$.?#].[^\\s]*$"
    },
    "localAppLink": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "regex": "^(https?|ftp)://[^\\s/$.?#].[^\\s]*$"
    },
    "internalInfo": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "softwareLink": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "regex": "^(https?|ftp)://[^\\s/$.?#].[^\\s]*$"
    },
    "googleCollabLink": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "regex": "^(https?|ftp)://[^\\s/$.?#].[^\\s]*$"
    },
    "available_at_KI_Lab": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "default": false
    },
    "provider": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "providerCountry": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "licenseType": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "open_source",
        "closed",
        "mixed"
      ]
    },
    "runsLocally": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "default": false
    },
    "licensedTrainingData": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "default": false
    }
  }
}
